# ── Banco de dados ────────────────────────────────
# Em desenvolvimento com Docker: use o host "postgres" (nome do serviço)
DATABASE_URL=postgresql://colortim:colortim_pass@postgres:5432/colortim_erp

# ── JWT ──────────────────────────────────────────
JWT_SECRET=troque_por_uma_string_aleatoria_de_64_caracteres_minimo
JWT_EXPIRES_IN=8h

# ── Backend ───────────────────────────────────────
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# ── Frontend (Vite) ───────────────────────────────
VITE_API_URL=http://localhost:3001
