# Banco de dados PostgreSQL
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/colortim"

# JWT - use pelo menos 64 caracteres aleatórios
JWT_SECRET="TROQUE_POR_UMA_STRING_MUITO_LONGA_E_ALEATORIA_MINIMO_64_CHARS"
JWT_EXPIRES_IN="8h"

# Servidor
PORT=3001
NODE_ENV=development

# CORS - URL do frontend
CORS_ORIGIN="http://localhost:5173"
