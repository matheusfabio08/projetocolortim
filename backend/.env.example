# Database
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/colortim_db"

# JWT - Use a strong secret (min 64 characters)
JWT_SECRET="change-this-to-a-very-long-random-secret-at-least-64-chars-long"
JWT_EXPIRES_IN="8h"

# Server
PORT=3001
NODE_ENV=development

# CORS - Frontend URL
CORS_ORIGIN="http://localhost:5173"

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=500
LOGIN_RATE_LIMIT_MAX=20
