# Database
DATABASE_URL="postgresql://user:password@localhost:5432/colortim_db"

# JWT - Use a strong random string (min 64 characters)
JWT_SECRET="change-this-to-a-very-long-random-secret-at-least-64-characters-long"
JWT_EXPIRES_IN="8h"

# Server
PORT=3001
NODE_ENV="development"

# CORS - Frontend URL
CORS_ORIGIN="http://localhost:5173"
